# ── Required secrets ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here       # LLM, embeddings, seeding
PINECONE_API_KEY=your_pinecone_api_key_here   # vector store (index auto-created on startup)
TAVILY_API_KEY=your_tavily_api_key_here        # live web search / fallback / deep research

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=production
APP_NAME=DeepResearchAgent
APP_VERSION=1.0.0

# ── Relational DB (metadata, sessions) ───────────────────────────
# SQLite default persists on the Reserved VM disk; swap for Postgres if desired.
DATABASE_URL=sqlite:///./data/rag_metadata.db

# ── Pinecone (defaults shown; override only if needed) ───────────
PINECONE_INDEX_NAME=deep-research-kb
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Knowledge base seeding (runs once on first boot) ─────────────
SEED_ON_STARTUP=true
SEED_MAX_PASSAGES=500      # 500 seeds in ~30s; keep low on memory-constrained hosts

# ── Optional ─────────────────────────────────────────────────────
# REDIS_URL=
